# Copy this file to .streamlit/secrets.toml for LOCAL testing of secrets behavior,
# or paste its contents into your app's Settings > Secrets on share.streamlit.io.
# Do NOT commit an actual secrets.toml with real keys -- .gitignore already excludes it.

GEMINI_API_KEY = "your-real-key-here"
MODEL = "gemini/gemini-flash-latest"

# Alternative providers (uncomment ONE set instead, remove the Gemini lines above):
# GROQ_API_KEY = "your-real-key-here"
# MODEL = "groq/openai/gpt-oss-20b"
#
# ANTHROPIC_API_KEY = "your-real-key-here"
# MODEL = "anthropic/claude-sonnet-5"
